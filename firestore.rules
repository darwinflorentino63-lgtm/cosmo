rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/chats/{chatId}
    // Document ID: Auto-generated
    // Fields:
    //   - role: string (required, 'user' or 'bot')
    //   - content: string (required, max 10000 chars)
    //   - sessionId: string (required, max 100 chars)
    //   - createdAt: number (required)
    //   - userId: string (required, must match owner)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidChatMessage() {
      let data = request.resource.data;
      return data.keys().hasAll(['role', 'content', 'sessionId', 'createdAt', 'userId']) &&
             data.keys().hasOnly(['role', 'content', 'sessionId', 'createdAt', 'userId']) &&
             (data.role == 'user' || data.role == 'bot') &&
             data.content is string && data.content.size() > 0 && data.content.size() < 10000 &&
             data.sessionId is string && data.sessionId.size() > 0 && data.sessionId.size() < 100 &&
             data.createdAt is number &&
             data.userId == request.auth.uid;
    }

    match /users/{userId}/chats/{chatId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidChatMessage();
      allow update: if isOwner(userId) && isValidChatMessage() && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId);
    }
  }
}
